# Copy this file to .env and fill in real values before deploying.

SECRET_KEY=replace-this-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,.railway.app

# Leave DATABASE_URL unset to use local sqlite3.
# Example for Postgres (Render/Railway will give you this automatically):
# DATABASE_URL=postgres://user:password@host:5432/dbname
